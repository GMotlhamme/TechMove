@model IEnumerable<TechMove.Models.Domain.Contract>

@{
    ViewData["Title"] = "Index";
}

<h1>User Contracts</h1>

<p>
    <a class="btn btn-dark" asp-action="Create">Create New Contract</a>
    <a class="btn btn-dark" asp-controller="Clients" asp-action="Index">Manage Clients</a>
</p>
<form asp-action="Index" method="get" class="mb-3">
    <div class="searchContainer">
        <div>
            <label>Status</label>
            <input type="text" name="status" value="@Context.Request.Query["status"]" placeholder="Search status..." class="form-control" />
        </div>

        <div>
            <label>Start Date</label>
            <input type="date" name="startDate" value="@Context.Request.Query["startDate"]" placeholder="Search start date..." class="form-control" />
        </div>

        <div>
            <label>End Date</label>
            <input type="date" name="endDate" value="@Context.Request.Query["endDate"]" placeholder="Search end date..." class="form-control" />
        </div>

        <a asp-action="Index" class="btn btn-outline-dark ">Clear</a>
        <button type="submit" class="btn btn-outline-dark ">Search</button>
    </div>
    <br />
</form>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.StartDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EndDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Status)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ServiceLevel)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.SignedAgreement)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Client)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.StartDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.EndDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Status)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ServiceLevel)
            </td>
            <td>
                    <a class="btn btn-outline-dark" href="@Html.DisplayFor(modelItem => item.SignedAgreement)" download="@Html.DisplayFor(modelItem => item.SignedAgreement)">download</a>
                
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Client)
            </td>
            <td>
                <a class="btn btn-dark" asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a class="btn btn-dark" asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a class="btn btn-dark" asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
